<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fr.framelab.controller.EditorController">
   <top>
      <HBox prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER" />
   </top>
   <left>
      <VBox prefHeight="200.0" prefWidth="100.0" BorderPane.alignment="CENTER" />
   </left>
   <bottom>
      <HBox prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER" />
   </bottom>
   <right>
      <VBox prefHeight="200.0" prefWidth="100.0" BorderPane.alignment="CENTER" />
   </right>
   <center>
      <SplitPane dividerPositions="0.5" prefHeight="160.0" prefWidth="200.0" BorderPane.alignment="CENTER">
        <items>
          <BorderPane minHeight="0.0" minWidth="0.0" prefHeight="160.0" prefWidth="100.0">
              <center>
                  <ScrollPane layoutX="-11.0" layoutY="-1.0" prefHeight="200.0" prefWidth="200.0">
                      <content>
                          <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="200.0" prefWidth="200.0">
                              <children>
                                  <ImageView fx:id="baseImage" fitHeight="150.0" fitWidth="200.0" layoutX="7.0" layoutY="25.0" pickOnBounds="true" preserveRatio="true" />
                              </children>
                          </AnchorPane>
                      </content>
                  </ScrollPane>
              </center>
          </BorderPane>
          <BorderPane minHeight="0.0" minWidth="0.0" prefHeight="198.0" prefWidth="241.0">
              <center>
                  <ScrollPane layoutX="-2.0" layoutY="7.0" prefHeight="200.0" prefWidth="200.0">
                      <content>
                          <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="200.0" prefWidth="200.0">
                              <children>
                                  <ImageView fx:id="editedImage" fitHeight="150.0" fitWidth="200.0" layoutX="-8.0" layoutY="14.0" pickOnBounds="true" preserveRatio="true" />
                              </children>
                          </AnchorPane>
                      </content>
                  </ScrollPane>
              </center>
          </BorderPane>
        </items>
      </SplitPane>
   </center>
</BorderPane>
