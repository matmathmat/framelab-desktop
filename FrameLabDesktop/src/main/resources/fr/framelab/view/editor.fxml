<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Group?>
<?import javafx.scene.shape.SVGPath?>
<BorderPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fr.framelab.controller.EditorController">
    <top>
        <HBox prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>

            <!-- Gauche -->
            <Button text="Amélioration"/>
            <Button text="Filtre"/>
            <Button text="Transformation"/>

            <!-- Separateur -->
            <Region HBox.hgrow="ALWAYS" />

            <!-- Droite -->
            <Button text="Sauvegarder"/>
            <Button text="Envoyer"/>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="60.0" spacing="15.0" alignment="CENTER" style="-fx-background-color: #f8f8f8;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="10.0" right="10.0" top="20.0" />
            </padding>

            <!-- Crayon -->
            <Button prefWidth="60.0" prefHeight="60.0" style="-fx-background-radius: 5;">
                <graphic>
                    <SVGPath content="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"
                             fill="transparent" stroke="black" strokeWidth="2"/>
                </graphic>
            </Button>

            <!-- Gomme -->
            <Button prefWidth="60.0" prefHeight="60.0" style="-fx-background-radius: 5;">
                <graphic>
                    <Group>
                        <SVGPath content="M21 21H8a2 2 0 0 1-1.42-.587l-3.994-3.999a2 2 0 0 1 0-2.828l10-10a2 2 0 0 1 2.829 0l5.999 6a2 2 0 0 1 0 2.828L12.834 21"
                                 fill="transparent" stroke="black" strokeWidth="2"/>
                        <SVGPath content="m5.082 11.09 8.828 8.828"
                                 fill="transparent" stroke="black" strokeWidth="2"/>
                    </Group>
                </graphic>
            </Button>

            <!-- Emoji -->
            <Button prefWidth="60.0" prefHeight="60.0" style="-fx-background-radius: 5;">
                <graphic>
                    <Group>
                        <SVGPath content="M12 2a10 10 0 1 0 0 20 10 10 0 1 0 0-20"
                                 fill="transparent" stroke="black" strokeWidth="2"/>
                        <SVGPath content="M8 14s1.5 2 4 2 4-2 4-2"
                                 fill="transparent" stroke="black" strokeWidth="2"/>
                        <SVGPath content="M9 9h.01M15 9h.01"
                                 fill="transparent" stroke="black" strokeWidth="2"/>
                    </Group>
                </graphic>
            </Button>
        </VBox>
    </left>

    <bottom>
        <HBox prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER" />
    </bottom>

    <right>
        <VBox prefHeight="200.0" prefWidth="100.0" BorderPane.alignment="CENTER" />
    </right>

    <center>
        <SplitPane dividerPositions="0.5" prefHeight="160.0" prefWidth="200.0" BorderPane.alignment="CENTER">
            <items>
                <BorderPane minHeight="0.0" minWidth="0.0" prefHeight="160.0" prefWidth="100.0">
                    <center>
                        <ScrollPane fx:id="leftScrollPane" fitToWidth="true" fitToHeight="true">
                            <content>
                                <ImageView fx:id="baseImage" pickOnBounds="true" preserveRatio="true" />
                            </content>
                        </ScrollPane>
                    </center>
                </BorderPane>
                <BorderPane minHeight="0.0" minWidth="0.0" prefHeight="198.0" prefWidth="241.0">
                    <center>
                        <ScrollPane fx:id="rightScrollPane" fitToWidth="true" fitToHeight="true">
                            <content>
                                <ImageView fx:id="editedImage" pickOnBounds="true" preserveRatio="true" />
                            </content>
                        </ScrollPane>
                    </center>
                </BorderPane>
            </items>
        </SplitPane>
    </center>

</BorderPane>