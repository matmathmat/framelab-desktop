<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox fx:id="root" alignment="CENTER_LEFT" spacing="6"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fr.framelab.controller.editor.LayerRowController">

    <padding>
        <Insets bottom="6.0" left="8.0" right="8.0" top="6.0" />
    </padding>

    <CheckBox fx:id="visibleCheckBox" />
    <Label fx:id="layerNameLabel" minWidth="60" HBox.hgrow="NEVER" />
    <Label text="Opacité:" style="-fx-font-size: 10px;" />
    <Slider fx:id="opacitySlider" min="0" max="100" value="100"
            prefWidth="75" blockIncrement="5" />
    <Label fx:id="opacityLabel" text="100%" minWidth="32"
           style="-fx-font-size: 10px;" />

    <Region HBox.hgrow="ALWAYS" />

    <Button fx:id="upButton"     text="↑" onAction="#handleUp" />
    <Button fx:id="downButton"   text="↓" onAction="#handleDown" />
    <Button fx:id="deleteButton" text="✕" onAction="#handleDelete" />
</HBox>
