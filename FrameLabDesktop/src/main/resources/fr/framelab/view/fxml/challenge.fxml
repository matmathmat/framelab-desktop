<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="400.0" prefWidth="600.0"
            styleClass="challenge-root"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="fr.framelab.controller.ChallengeController"
            stylesheets="@/fr/framelab/view/css/challenge.css">

    <left>
        <VBox prefHeight="200.0" prefWidth="100.0" styleClass="challenge-info-panel" BorderPane.alignment="CENTER">
            <children>
                <ImageView fx:id="challengeImage" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" styleClass="challenge-image" />
                <Label fx:id="titleThemeLabel"       styleClass="challenge-title" text="Label" />
                <Label fx:id="descriptionThemeLabel" styleClass="challenge-desc"  text="Label" />
                <Label fx:id="startDateLabel"        styleClass="challenge-date"  text="Label" />
                <Label fx:id="endDateLabel"          styleClass="challenge-date"  text="Label" />
                <Button mnemonicParsing="false" onAction="#handleParticipate" styleClass="btn-accent" text="Participer" />
            </children>
        </VBox>
    </left>
</BorderPane>
