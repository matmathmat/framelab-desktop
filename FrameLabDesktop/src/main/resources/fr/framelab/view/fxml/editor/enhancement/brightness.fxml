<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="popup-root"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="fr.framelab.controller.editor.enhancement.BrightnessController"
            stylesheets="@/fr/framelab/view/css/editor/enhancement/brightness.css">

    <!-- Top -->
    <top>
        <Label styleClass="popup-title" text="Luminosité" BorderPane.alignment="CENTER" />
    </top>

    <!-- Centre -->
    <center>
        <VBox alignment="CENTER" spacing="10.0" styleClass="popup-content">
            <Slider fx:id="slider" max="100" min="-100" value="0" styleClass="nb-slider" />
            <Label fx:id="valueLabel" text="${slider.value}" styleClass="popup-value-label" />
        </VBox>
    </center>

    <!-- Bas -->
    <bottom>
        <HBox alignment="CENTER" spacing="10" styleClass="popup-actions">
            <Button onAction="#handleApply" text="Appliquer" styleClass="btn-primary" />
            <Button onAction="#handleCancel" text="Annuler" styleClass="btn-secondary" />
        </HBox>
    </bottom>
</BorderPane>