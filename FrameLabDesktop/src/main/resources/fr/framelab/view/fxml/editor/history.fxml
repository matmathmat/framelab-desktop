<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="fr.framelab.controller.editor.HistoryController">

    <!-- Top -->
    <top>
        <VBox>
            <Label style="-fx-font-weight: bold; -fx-font-size: 14px;" text="Historique des actions">
                <padding><Insets bottom="8" left="12" right="12" top="12"/></padding>
            </Label>
            <Separator/>
        </VBox>
    </top>

    <!-- Liste des actions -->
    <center>
        <ListView fx:id="historyList" style="-fx-border-color: transparent;">
            <padding><Insets bottom="4" left="8" right="8" top="4"/></padding>
        </ListView>
    </center>

    <!-- Bas -->
    <bottom>
        <VBox>
            <Separator/>
            <HBox alignment="CENTER_RIGHT" spacing="10">
                <padding><Insets bottom="12" left="12" right="12" top="10"/></padding>
                <Label text="Cliquez sur une action pour prévisualiser"
                       style="-fx-text-fill: #777; -fx-font-size: 11px;"
                       HBox.hgrow="ALWAYS"/>
                <Button fx:id="cancelButton" text="Annuler" onAction="#handleCancel"/>
                <Button fx:id="okButton"     text="OK"      onAction="#handleOk"
                        style="-fx-background-color: #0078d4; -fx-text-fill: white;"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
