<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane styleClass="history-root"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="fr.framelab.controller.editor.HistoryController"
            stylesheets="@/fr/framelab/view/css/editor/history.css">

    <!-- Top -->
    <top>
        <VBox>
            <Label styleClass="history-title" text="Historique des actions">
                <padding><Insets bottom="8" left="12" right="12" top="12"/></padding>
            </Label>
            <Separator styleClass="nb-separator"/>
        </VBox>
    </top>

    <!-- Liste des actions -->
    <center>
        <ListView fx:id="historyList" styleClass="history-list">
            <padding><Insets bottom="4" left="8" right="8" top="4"/></padding>
        </ListView>
    </center>

    <!-- Bas -->
    <bottom>
        <VBox>
            <Separator styleClass="nb-separator"/>
            <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="history-actions">
                <padding><Insets bottom="12" left="12" right="12" top="10"/></padding>
                <Label text="Cliquez sur une action pour prévisualiser"
                       styleClass="history-info"
                       HBox.hgrow="ALWAYS"/>
                <Button fx:id="cancelButton" text="Annuler" onAction="#handleCancel" styleClass="btn-secondary"/>
                <Button fx:id="okButton"     text="OK"      onAction="#handleOk"     styleClass="btn-primary"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>