<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER"
      spacing="0"
      prefWidth="400"
      styleClass="project-panel"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fr.framelab.controller.home.ProjectPanelController"
      stylesheets="@/fr/framelab/view/css/home/project_panel.css">

    <Label text="Mes projets" styleClass="panel-title">
        <padding>
            <javafx.geometry.Insets bottom="8.0" left="12.0" right="12.0" top="12.0" />
        </padding>
    </Label>

    <Separator styleClass="nb-separator" />

    <Accordion fx:id="accordion" styleClass="panel-accordion" VBox.vgrow="ALWAYS" />

    <Label fx:id="emptyLabel"
           text="Aucun projet pour l'instant.&#10;Participez à un challenge !"
           styleClass="empty-label"
           wrapText="true"
           visible="false" managed="false">
        <padding>
            <javafx.geometry.Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
        </padding>
    </Label>

</VBox>
