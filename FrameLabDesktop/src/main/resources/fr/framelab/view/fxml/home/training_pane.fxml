<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fr.framelab.controller.home.TrainingPaneController"
      styleClass="training-pane"
      spacing="10" alignment="TOP_CENTER"
      stylesheets="@/fr/framelab/view/css/home/training_pane.css">

    <Label text="Entraînement du jour" styleClass="pane-title" />

    <Separator styleClass="nb-separator" />

    <ImageView fx:id="trainingImage"
               fitWidth="220" fitHeight="140"
               preserveRatio="true" pickOnBounds="true"
               styleClass="training-image" />

    <Label fx:id="countdownLabel"
           text="Réinitialisation dans : --:--:--"
           styleClass="countdown-label" />

    <Label fx:id="completedBadge"
           text="✅  Déjà complété aujourd'hui !"
           styleClass="completed-badge"
           visible="false" managed="false" />

    <Label text="Opérations à effectuer :" styleClass="section-label" />

    <ListView fx:id="operationsList"
              styleClass="operations-list"
              prefHeight="150"
              maxWidth="Infinity" />

    <Region VBox.vgrow="ALWAYS" />

    <Button fx:id="startButton"
            text="Commencer l'entraînement"
            styleClass="btn-accent"
            maxWidth="Infinity"
            onAction="#handleStart" />
</VBox>
