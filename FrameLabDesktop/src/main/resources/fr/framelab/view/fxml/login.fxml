<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="400.0" prefWidth="600.0"
            styleClass="login-root"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="fr.framelab.controller.LoginController"
            stylesheets="@/fr/framelab/view/css/login.css">

    <center>
        <StackPane>
            <VBox alignment="CENTER" maxWidth="450" maxHeight="-Infinity" spacing="15" styleClass="login-form">
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="form-row">
                    <Label minWidth="100" styleClass="form-label" text="Email" />
                    <TextField fx:id="emailTextField" styleClass="form-field" HBox.hgrow="ALWAYS" />
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="form-row">
                    <Label minWidth="100" styleClass="form-label" text="Mot de passe" />
                    <PasswordField fx:id="passwordTextField" styleClass="form-field" HBox.hgrow="ALWAYS" />
                </HBox>

                <HBox alignment="CENTER" spacing="10" styleClass="form-actions">
                    <VBox.margin>
                        <Insets top="14" />
                    </VBox.margin>
                    <Button fx:id="loginButton" mnemonicParsing="false" onAction="#handleLogin" styleClass="btn-primary" text="Se connecter" />
                    <Button fx:id="guestButton" mnemonicParsing="false" onAction="#handleGuest" styleClass="btn-secondary" text="Continuer en tant qu'invité" />
                </HBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>