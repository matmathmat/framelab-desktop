<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="4"
      style="-fx-border-color: #ddd; -fx-border-width: 0 0 1 0;"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fr.framelab.controller.home.ProjectItemController">

    <padding>
        <Insets bottom="10.0" left="8.0" right="8.0" top="10.0" />
    </padding>

    <Label fx:id="titleLabel" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: black;" />
    <Label fx:id="createdLabel" style="-fx-font-size: 11px; -fx-text-fill: #666;" />
    <Label fx:id="editedLabel" style="-fx-font-size: 11px; -fx-text-fill: #666;" />
    <HBox spacing="8" alignment="CENTER_RIGHT">
        <VBox.margin>
            <Insets top="5.0" />
        </VBox.margin>
        <Button fx:id="openBtn" text="Ouvrir" onAction="#handleOpen" />
        <Button fx:id="deleteBtn" text="Supprimer" onAction="#handleDelete" style="-fx-text-fill: red;" />
    </HBox>

</VBox>